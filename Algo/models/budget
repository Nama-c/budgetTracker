Classe Budget

    private idBudget : Entier
    private idUtilisateur : Entier
    private idCategorie : Entier
    private montantMaximum : Réel
    private montantConsomme : Réel
    private montantRestant : Réel
    private derniereMiseAJour : DateHeure
    private nomCategorie : Chaîne

    public Budget(
        idBudget,
        idUtilisateur,
        idCategorie,
        montantMaximum,
        montantConsomme,
        montantRestant,
        derniereMiseAJour,
        nomCategorie
    )
        debut

            this.idBudget <- idBudget
            this.idUtilisateur <- idUtilisateur
            this.idCategorie <- idCategorie
            this.montantMaximum <- montantMaximum
            this.montantConsomme <- montantConsomme
            this.montantRestant <- montantRestant
            this.derniereMiseAJour <- derniereMiseAJour
            this.nomCategorie <- nomCategorie

        fin

    public fonction getIdBudget() : Entier
        debut

            retourner this.idBudget

        fin

    public procedure setIdBudget(idBudget)
        debut

            this.idBudget <- idBudget

        fin

    public fonction getIdUtilisateur() : Entier
        debut

